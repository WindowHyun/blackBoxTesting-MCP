# Browser
HEADLESS=true            # set false to watch the browser
BROWSER=chromium         # chromium | firefox | webkit
# Use a pre-provisioned browser binary instead of Playwright's bundled download.
# Auto-detected at /opt/pw-browsers/chromium if present (managed/CI envs where
# the browser CDN is blocked). Set explicitly to override.
# CHROMIUM_EXECUTABLE=/opt/pw-browsers/chromium

# Use an installed browser channel (real Chrome/Edge) — real UA reduces anti-bot
# false positives on sites with bot detection. Requires that browser installed.
# BROWSER_CHANNEL=chrome
# Light anti-automation-fingerprint hardening for legitimate testing
# (disables AutomationControlled, real UA/locale/timezone, hides webdriver flag).
# STEALTH=false

# Attach to YOUR already-running, logged-in browser instead of launching one.
# Best for sites with bot detection / login: you handle login & CAPTCHA in your
# real browser, automation runs in that real session (least bot-flagging).
# Launch Chrome first:  chrome --remote-debugging-port=9222 --user-data-dir=...
# BROWSER_CDP=http://localhost:9222

# Output paths
# 절대경로 권장(미설정 시 ~/ui-blackbox/... 사용)
# REPORT_DIR=/abs/path/reports
# SCENARIO_DIR=/abs/path/scenarios
# REPORT_RETENTION=100              # 최근 N개 실행만 보관(스크린샷 포함), 0=무제한

# Behavior
SELECTOR_TIMEOUT_MS=2000          # 실 사이트(지연 로딩)면 5000~10000 권장
DEFAULT_WAIT_UNTIL=networkidle    # 광고/폴링 많은 실 사이트면 domcontentloaded 권장
NAV_TIMEOUT_MS=30000              # 초과 시 networkidle 포기하고 현재 상태로 진행
IGNORE_HTTPS_ERRORS=false         # 스테이징 사설/만료 인증서면 true

# Credentials referenced from scenarios as ${VAR} (never stored in reports)
# EXAMPLE_PASSWORD=changeme
